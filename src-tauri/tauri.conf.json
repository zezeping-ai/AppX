{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AppX",
  "version": "0.2.1",
  "identifier": "com.zezeping.appx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AppX",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "busy_timeout": 2000,
      "logLevel": "off"
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDRkMzNzc0QjZCN0U4RDcKUldUWDZMZTJkRGY4WEU0NXF5REdKVEpBSXMzanNnSS9Nc3M4bHlsNDZOZVQ0QXh5UTVzcmNEMkoK",
      "endpoints": [
        "https://github.com/zezeping-ai/AppX/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["txt.x"],
        "name": "AppX Encrypted Text",
        "description": "AppX encrypted text document",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": ["js.x"],
        "name": "AppX Encrypted JavaScript",
        "description": "AppX encrypted JavaScript document",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": ["java.x"],
        "name": "AppX Encrypted Java",
        "description": "AppX encrypted Java document",
        "role": "Editor",
        "rank": "Owner"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
